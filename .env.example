# Backend runtime
PORT=5000
DB_USER=vfd_user
DB_HOST=localhost
DB_NAME=vfd_db
DB_PASSWORD=vfd_password
DB_PORT=5432

# Auth and HTTP security
JWT_SECRET=change_me
JWT_EXPIRES_IN=1d
# Comma-separated. Leave unset in local development for permissive CORS.
# CORS_ORIGIN=http://localhost:5173,https://example.com

# Storage
STORAGE_TYPE=LOCAL
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_BYTES=10485760

# Optional SMB defaults for preconfigured deployments
# SMB_HOST=192.168.1.100
# SMB_SHARE=Public
# SMB_USER=vfd_user
# SMB_PASS=change_me
# SMB_BASE_PATH=!variadores\Informes Variadores

# Email defaults. Values are persisted to vfd.settings on first use if absent.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_REJECT_UNAUTHORIZED=true
EMAIL_FROM_NAME=VFD Workflow

# Frontend build-time config
# Docker/Nginx and same-origin deployments should use /api.
# For local Vite without the proxy, use http://localhost:5000/api.
VITE_API_BASE_URL=/api
